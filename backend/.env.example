# ── Copy this file to .env and fill in the values ─────────────────────────────

# Core
DEBUG=false
LOG_LEVEL=INFO

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_HOURS=168

# Database
DATABASE_URL=postgresql+asyncpg://jobmatch:CHANGE_ME@localhost:5432/jobmatch
SYNC_DATABASE_URL=postgresql://jobmatch:CHANGE_ME@localhost:5432/jobmatch

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Job search (optional)
RAPIDAPI_KEY=

# Email — works with Gmail App Password, SendGrid SMTP, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=JobMatch AI <you@gmail.com>
# Public-facing URL used in password-reset emails
APP_URL=http://localhost:3000

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Rate limits
RATE_LIMIT_ANALYZE=15/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_OPTIMIZE=10/minute
RATE_LIMIT_GLOBAL=120/minute

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
FILE_RETENTION_DAYS=30
